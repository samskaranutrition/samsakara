# Calendly — discovery call booking (date/time picker + email notifications)
# 1. Create a free account at https://calendly.com
# 2. Add an event type (e.g. "Discovery call", 15 minutes)
# 3. Paste the full event URL below, then restart `npm run dev`
# 4. On Netlify: Site settings → Environment variables → add VITE_CALENDLY_URL → redeploy
VITE_CALENDLY_URL=https://calendly.com/samskaranutrition

# Optional — Calendly event type with Stripe payments enabled for programme fees
# If unset, programme booking links fall back to VITE_CALENDLY_URL
VITE_CALENDLY_PROGRAMME_URL=

# Calendly payment collection links per programme (defaults baked into site.ts)
VITE_CALENDLY_ARTHA_URL=https://calendly.com/samskaranutrition/payments/7e33e37c-0e12-4fcd-9cfe-3dbf85126b57
VITE_CALENDLY_SETU_URL=https://calendly.com/samskaranutrition/payments/b27bf691-e237-4b65-b043-7abb1c8d8a1e
VITE_CALENDLY_SAMSKARA_URL=https://calendly.com/samskaranutrition/payments/622b06f3-3e3c-45bd-8d33-a0876d9e62fe

# Optional — Stripe Payment Link (no backend required). Takes priority over Calendly programme URL.
# Create at https://dashboard.stripe.com/payment-links
VITE_STRIPE_PAYMENT_URL=

# Calendly dashboard (manual): mirror booking consent text as required custom questions on
# discovery + paid event types, and on payment collection pages where Calendly allows it.
# On-site gates at /programmes and /intake record consent before clients reach Calendly.
